# Copy this file to `.env` (which is gitignored) OR run `npm run gen` to create it.
# These are TESTNET-ONLY keys. NEVER put a key holding real funds here, and NEVER commit .env.

# Wallet A = sender (must be funded with test USDC).
PRIVATE_KEY_A=0xYOUR_SENDER_PRIVATE_KEY
WALLET_A_ADDRESS=0xYOUR_SENDER_ADDRESS

# Wallet B = recipient.
PRIVATE_KEY_B=0xYOUR_RECIPIENT_PRIVATE_KEY
WALLET_B_ADDRESS=0xYOUR_RECIPIENT_ADDRESS

# Optional RPC overrides (defaults are the public endpoints).
# ARC_RPC_URL=https://rpc.testnet.arc.network
# BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# --- Relay service (npm start / Railway) ---
# The seller wallet that RECEIVES USDC on Arc. Address only — the relay holds NO key.
RELAY_WALLET_ADDRESS=0xYOUR_SELLER_WALLET_ADDRESS
# PORT is injected by Railway; locally defaults to 8080.
# PORT=8080
