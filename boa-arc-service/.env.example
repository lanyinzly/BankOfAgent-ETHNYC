# BoA × Arc — copy to Railway Variables (NEVER commit real keys; testnet only).

# Arc testnet RPC (USDC is the 6-dp ERC-20 at 0x3600…0000; gas is paid in USDC).
ARC_RPC_URL=https://rpc.testnet.arc.network

# ── app service (index.ts) ──────────────────────────────────────────────────
# Buyer agent key — pays USDC on Arc (server-side only, testnet). Fund it at the
# Arc faucet. Without it /api/agent/buy + /api/settle are disabled (reads still work).
AGENT_PRIVATE_KEY=0xYOUR_TESTNET_BUYER_KEY
# Seller address = the relay's payTo (its USDC receiver). Used for balances + buy.
RELAY_WALLET_ADDRESS=0xSELLER_WALLET
# The deployed seller relay service URL (the relay service below).
RELAY_URL=https://boa-arc-relay-production.up.railway.app
# Recipient for the plain /api/settle 1-USDC transfer (defaults to RELAY_WALLET_ADDRESS).
RECIPIENT=0xWALLET_B
# Frontend origin allowed by CORS (default * for the hackathon).
ALLOWED_ORIGIN=*

# ── relay service (relay.ts) — deploy as a SECOND Railway service ────────────
# Same repo dir; set the service's start command to `node relay.ts`. NO private key.
# RELAY_WALLET_ADDRESS = the seller's USDC receiver (its payTo).
# ARC_RPC_URL as above. RELAY_PRICE_PER_1K = floor price (default 0.02).
RELAY_PRICE_PER_1K=0.02

# PORT is provided by Railway.
