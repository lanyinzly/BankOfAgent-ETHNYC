# boa-ens-service — copy to Railway Variables (NEVER commit real secrets).

# A reliable Sepolia RPC (Alchemy/Infura strongly recommended — the /agents
# discovery does a getLogs scan; flaky public RPCs cap block ranges / rate-limit).
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# The funded key that OWNS FLEET_PARENT. Lives ONLY here (server side). Without it
# the service runs read-only (discovery + resolve work; minting is disabled).
PRIVATE_KEY=0xYOUR_FUNDED_FLEET_OWNER_KEY

# The agent fleet's ENS root — the service mints subnames under this. The key
# above MUST own it (see /health.fleetOwnedByUs).
FLEET_PARENT=bankofagent-37d9ba.eth

# Canonical Sepolia ENS addresses (defaults already correct; override only if needed).
ENS_REGISTRY=0x00000000000C2E074eC69A0dFb2997BA6C7d2e1e
PUBLIC_RESOLVER=0xE99638b40E4Fff0129D56f03b55b6bbC4BBE49b5
CONTROLLER=0xdf60C561Ca35AD3C89D24BbA854654b1c3477078

# Frontend origin allowed by CORS (default * for hackathon).
CORS_ORIGIN=*

# Optional: speed up discovery on capped public RPCs by starting the NewOwner scan
# at the fleet's creation block (skip if using Alchemy/Infura).
# BOA_ENS_START_BLOCK=9100000
# BOA_ENS_LOG_CHUNK=45000

# PORT is provided by Railway.
